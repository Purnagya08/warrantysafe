generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  notifications Notification[]
}

model Product {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  brand         String?
  category      String?
  purchaseDate  DateTime?
  purchasePrice Float?
  retailerName  String?
  serialNumber  String?
  modelNumber   String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  warranty      Warranty?
  documents     Document[]
  repairs       Repair[]
}

model Warranty {
  id               String          @id @default(cuid())
  productId        String          @unique
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  startDate        DateTime?
  endDate          DateTime?
  warrantyType     WarrantyType    @default(MANUFACTURER)
  providerName     String?
  coverageDetails  String?
  reminderSent     Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId        String
  type          DocumentType @default(OTHER)
  fileUrl       String
  fileName      String
  fileSize      Int?
  mimeType      String?
  extractedData Json?
  uploadedAt    DateTime     @default(now())
}

model Repair {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  issue        String
  status       RepairStatus @default(PENDING)
  repairCenter String?
  cost         Float?
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType @default(GENERAL)
  title        String
  body         String
  isRead       Boolean          @default(false)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime         @default(now())
}

enum WarrantyType {
  MANUFACTURER
  EXTENDED
  STORE
}

enum DocumentType {
  RECEIPT
  INVOICE
  MANUAL
  WARRANTY_CARD
  OTHER
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  WARRANTY_EXPIRY
  REPAIR_UPDATE
  DOCUMENT_PROCESSED
  GENERAL
}